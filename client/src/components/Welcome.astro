---
import "../styles/index.css";
import Layout from "../layouts/Layout.astro";
import Navbar from "./Navbar.astro";
---
<Layout>
      <div
      class="floating-google-login"
      onclick="location.href ='/Login'"
    >
      <svg
        width="28"
        height="28"
        viewBox="0 0 48 48"
        style="vertical-align: middle"
      >
        <g>
          <path
            fill="#4285F4"
            d="M43.6 20.5h-1.9V20H24v8h11.3c-1.6 4.3-5.7 7-11.3 7-6.6 0-12-5.4-12-12s5.4-12 12-12c2.7 0 5.2 0.9 7.2 2.5l6-6C34.2 5.1 29.4 3 24 3 12.9 3 4 11.9 4 23s8.9 20 20 20c11 0 19.7-8 19.7-20 0-1.3-0.1-2.7-0.3-3.5z"
          />
          <path
            fill="#34A853"
            d="M6.3 14.7l6.6 4.8C14.5 16.1 18.9 13 24 13c2.7 0 5.2 0.9 7.2 2.5l6-6C34.2 5.1 29.4 3 24 3 16.3 3 9.4 7.7 6.3 14.7z"
          />
          <path
            fill="#FBBC05"
            d="M24 43c5.3 0 10-1.8 13.7-4.9l-6.3-5.2C29.2 34.6 26.7 35.5 24 35.5c-5.6 0-10.3-3.8-12-9l-6.6 5.1C9.4 40.3 16.3 45 24 45z"
          />
          <path
            fill="#EA4335"
            d="M43.6 20.5h-1.9V20H24v8h11.3c-0.7 2-2.1 3.7-3.9 4.9l6.3 5.2C41.8 36.2 44 30.9 44 24c0-1.3-0.1-2.7-0.4-3.5z"
          />
        </g>
      </svg>
      <span>Google</span>
    </div>
    <Navbar/>
    <header class="header">
      <h1>Trace<span>Vault</span></h1>
      <p>Lost something? Found something? Let's connect the dots.</p>
    </header>

    <main class="container">
      <section class="card">
        <h2>Report Lost Item</h2>
        <p>Help us find your belongings by submitting a report.</p>
        <a href="/Report">
          <button>Report Now</button>
        </a>
      </section>

      <section class="card">
        <h2>View Found Items</h2>
        <p>Check the list of items people have found around campus.</p>
        <a href="/Explore">
          <button>Explore</button>
        </a>
      </section>
      
      <!-- <section class="card">
        <h2>Trace Item</h2>
        <p>Enter your Trace ID to check the status of your report.</p>
        <a href="/Trace">
          <button>Trace Item</button>
        </a>
      </section> -->
    </main>

    <footer class="footer">
      <p>&copy; 2025 TraceVault | Built with purpose.</p>
    </footer>

</Layout>
