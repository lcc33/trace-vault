---
import Layout from "../layouts/Layout.astro"
---
<style>
  .menu-toggle {
    position: fixed;
    top: 1rem;
    left: 1rem;
    width: 50px;
    height: 50px;
    background: #1e293b;
    border-radius: 50%;
    border: none;
    cursor: pointer;
    z-index: 1000;
    display: flex;
    justify-content: center;
    align-items: center;
    transition: background 0.3s ease;
  }

  .menu-toggle:hover {
    background: #0f172a;
  }

  .menu {
    position: fixed;
    top: 4rem;
    left: 1rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    opacity: 0;
    transform: scale(0);
    transition: transform 0.4s cubic-bezier(0.68, -0.55, 0.27, 1.55), opacity 0.3s ease;
    z-index: 999;
    margin-left: 20px;
  }

  .menu.show {
    opacity: 1;
    transform: scale(1);
  }

  .menu-icon {
    width: 40px;
    height: 40px;
    background: #38bdf8;
    border-radius: 12px;
    padding: 0.5rem;
    cursor: pointer;
    transition: transform 0.2s ease;
  }

  .menu-icon:hover {
    transform: scale(1.2);
    background: #0ea5e9;
  }

  @media (max-width: 700px) {
    .menu {
      flex-direction: row;
      top: 1rem;
      left: 100px;
      align-items: center;
      gap: 3rem;
      margin-left: 50px;
    }
  }
</style>
<Layout>
<button class="menu-toggle" onclick="toggleMenu()">
  <img src="https://img.icons8.com/ios-glyphs/30/ffffff/menu--v2.png" alt="Menu"/>
</button>

<div class="menu" id="menu">
  <img src="https://img.icons8.com/ios-glyphs/30/ffffff/user--v1.png" class="menu-icon" alt="Profile" onclick="location.href='#'"/>
  <img src="https://img.icons8.com/ios-glyphs/30/ffffff/appointment-reminders--v1.png" class="menu-icon" alt="Notifications" onclick="location.href='#'"/>
  <img src="https://img.icons8.com/ios-glyphs/30/ffffff/logout-rounded--v1.png" class="menu-icon" alt="Logout" onclick="logoutUser()"/>
</div>

<script is:inline>
  function toggleMenu() {
    document.getElementById('menu').classList.toggle('show');
  }

  function logoutUser() {
    // clear tokens/session
    console.log('User logged out');
    location.href = './';
  }
</script>
</Layout>