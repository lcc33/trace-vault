---
import Layout from "../layouts/Layout.astro";
---

<!-- Navbar.astro -->
<style>
  body {
  }
  .menu-toggle {
    position: fixed;
    top: 10px;
    right: 1rem;
    background: transparent;
    /* background: #1e293b; */
    background: rgba(30, 41, 59, 0.85);
    /* border-radius: 50%; */
    border: none;
    cursor: pointer;
    z-index: 100;
    display: flex;
    opacity: 0;
    justify-content: center;
    align-items: center;
    transition: transform 0.3s ease;
  }

  .menu-toggle:hover {
    transform: scale(1.2);
  }

  .menu {
    position: fixed;
    top: 2rem;
    right: 1rem; /* changed from right to left */
    flex-direction: row;
    gap: 3rem;
    display: flex;
    transform: scale(1);
    opacity: 1;
    transition:
      transform 0.4s cubic-bezier(0.68, -0.55, 0.27, 1.55),
      opacity 0.3s ease;
    z-index: 999;
  }

  .mobileMenu.show {
    opacity: 1;
    transform: scale(1);
  }

  .menu-icon {
    width: 40px;
    height: 40px;
    background: #38bdf8;
    border-radius: 12px;
    padding: 0.5rem;
    cursor: pointer;
    transition: transform 0.2s ease;
  }

  .menu-icon:hover {
    transform: scale(1.2);
    background: rgba(30, 41, 59, 0.85);
  }
  .mobileMenu {
    position: fixed;
    top: 3rem;
    right: 1rem; /* changed from right to left */
    flex-direction: row;
    gap: 3rem;
    display: flex;
    transform: scale(0);
    opacity: 0;
    /* transform: scale(0); */
    transition:
      transform 0.4s cubic-bezier(0.68, -0.55, 0.27, 1.55),
      opacity 0.3s ease;
    z-index: 999;
  }
  @media (max-width: 700px) {
    .menu-toggle {
      opacity: 1;
      display: flex;
    }
    .menu {
      display: none;
      /* opacity: 0 */
    }
  }
</style>
<Layout>
  <img
    src="https://img.icons8.com/ios-glyphs/30/ffffff/menu--v2.png"
    alt="Menu"
    onclick="toggleMenu()"
    class="menu-toggle"
  />

  <div class="menu" id="menu">
    <img
      src="https://img.icons8.com/ios-glyphs/30/ffffff/appointment-reminders--v1.png"
      class="menu-icon"
      alt="Notifications"
      title="Notifications"
      onclick="location.href='/notifications'"
    />
    <img
      src="https://img.icons8.com/ios-glyphs/30/ffffff/user--v1.png"
      class="menu-icon"
      alt="Profile"
      title="Profile"
      onclick="location.href='/profile'"
    />

 <a href="http://locahost:5000/auth/logout">
<img
      src="https://img.icons8.com/ios-glyphs/30/ffffff/logout-rounded--v1.png"
      class="menu-icon"
      alt="Logout"
      title="Logout"
      onclick="location.href"
    />
</a>
  </div>

  <div class="mobileMenu" id="mobileMenu">
    <img
      src="https://img.icons8.com/ios-glyphs/30/ffffff/appointment-reminders--v1.png"
      class="menu-icon"
      alt="Notifications"
      title="Notifications"
      onclick="location.href='/notifications'"
    />
    <img
      src="https://img.icons8.com/ios-glyphs/30/ffffff/user--v1.png"
      class="menu-icon"
      alt="Profile"
      title="Profile"
      onclick="location.href='/profile'"
    />
<a href="http://locahost:5000/auth/logout">
<img
      src="https://img.icons8.com/ios-glyphs/30/ffffff/logout-rounded--v1.png"
      class="menu-icon"
      alt="Logout"
      title="Logout"
      onclick="location.href"
    />
</a>
    
  </div>

  <script is:inline>
    function toggleMenu() {
      document.getElementById("mobileMenu").classList.toggle("show");
    }

    function logoutUser() {
      // clear tokens/session
      console.log("User logged out");
      // redirect if you want:

      fetch("http://locahost:5000/auth/logout")
        .then((res) => res.json())
        .then((data) => console.log(data));
    }
  </script>
</Layout>
